# ── Ollama LLM Server ────────────────────────────────────────────────────────
# URL of your Ollama instance (local or remote)
OLLAMA_HOST=http://localhost:11434

# Basic auth credentials (leave blank if your Ollama has no auth)
OLLAMA_USER=
OLLAMA_PASSWORD=

# Bearer token auth — alternative to basic auth (leave blank if not used)
OLLAMA_API_KEY=

# ── Anthropic Claude (optional) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Backend ───────────────────────────────────────────────────────────────────
# Port for the Express backend (default: 80 inside Docker, 3001 locally)
PORT=3001

# ── Frontend (Create React App) ───────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:3001
REACT_APP_DEFAULT_MODEL=llama3.2
